# Environment Variables Template
# Copy this file to .env.local and fill in your values

# API Configuration
# Direct backend API URL (used in Normal mode, and on Next.js server)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# API Routing Mode: set to "true" to enable client-side reverse proxying through Vercel (Proxy mode), or "false" to connect directly (Normal mode)
NEXT_PUBLIC_API_PROXY_MODE=true

# Local backend target URL to proxy to (only used when proxy mode is true. Server-side only.)
BACKEND_PROXY_URL=https://xxxx-xx-xx-xx.ngrok-free.app

# Feature Flags (if needed)
# VITE_FEATURE_ANALYTICS=true

# Demo Mode — set to "true" on Vercel to show mock data without a backend
# NEXT_PUBLIC_DEMO_MODE=true
